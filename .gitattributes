# Auto-detect text files and ensure consistent line endings
* text=auto

# Force LF for source files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf

# Force CRLF for Windows-specific scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
